# ---- BBDV site environment ----

# OPTIONAL: URL of the deployed chatbot service on Render (recommended for production).
# If set, the chat widget calls this. If left blank, the widget uses the built-in
# Next.js /api/chat route instead (which needs GEMINI_API_KEY below).
# Example: https://bbdv-chatbot.onrender.com
NEXT_PUBLIC_CHATBOT_URL=

# Needed ONLY if you use the built-in /api/chat route (i.e. NEXT_PUBLIC_CHATBOT_URL is blank).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Lead capture ----
# Where captured leads (from the chat and the quote form) are saved.
# Default ./data/leads.json. Works locally and on a host with a persistent disk.
# For Vercel production, swap the store in src/lib/leads-store.ts for a managed
# database (Supabase / Postgres / Vercel KV) and this path is no longer used.
LEADS_FILE=data/leads.json

# OPTIONAL: when set, the future admin dashboard read API (GET /api/leads) requires
# this token via the `x-admin-token` header or `?token=`. Leave blank in dev.
ADMIN_TOKEN=
